# Copy to .env in this directory (packages/voice-agent-backend/.env).
# That file is gitignored. Do not put server API keys in test-app/.env (VITE_* is for the frontend only).
#
# Run: npm run start   (or npm run backend) from this directory.

# At least one of Deepgram or OpenAI is required for the combined test-app backend.
#DEEPGRAM_API_KEY=
#OPENAI_API_KEY=

#PROXY_PORT=8080

# Optional: HTTPS=true for local wss:// (see test-app backend docs)
